# Retrieval models
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages: 
EMBEDDING_DOCUMENT_PREFIX=
RERANKER_MAX_LENGTH=1024

# Retrieval behavior: auto, hybrid, or sparse
RAG_RETRIEVAL_BACKEND=auto
DENSE_TOP_K=24
SPARSE_TOP_K=24
FUSED_TOP_K=20
RERANK_TOP_K=6
RRF_K=60
USE_RETRIEVAL_HEURISTICS=1
USE_RERANK_HEURISTICS=1

# Chunking
CHUNK_SIZE_TOKENS=280
CHUNK_OVERLAP_TOKENS=40
MIN_CHUNK_TOKENS=90
DEFINITIONAL_MICROCHUNK_MAX_TOKENS=180

# Optional local answer model
MAX_NEW_TOKENS=512
MEDGEMMA_MODEL_NAME_OR_PATH=

# Hugging Face cache behavior on Windows
HF_HUB_DISABLE_SYMLINKS_WARNING=1
